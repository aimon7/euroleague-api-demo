{
  "name": "euroleague-api-demo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "postbuild": "node scripts/pages-postbuild.mjs",
    "preview": "vite preview",
    "serve:dist": "vite preview --outDir dist/client",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "gen:sdk-manifest": "node scripts/gen-sdk-manifest.mjs",
    "check:catalog": "vitest run src/lib/docs/catalog-drift.test.ts",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx}\"",
    "check": "prettier --check \"**/*.{ts,tsx,js,jsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/vite": "^4",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "1.170.16",
    "@tanstack/react-router-ssr-query": "1.167.1",
    "@tanstack/react-start": "1.168.26",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "euroleague-api": "^1.1.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "3.8.0",
    "shadcn": "^4.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tanstack/devtools-vite": "0.8.1",
    "@tanstack/eslint-config": "0.4.0",
    "@tanstack/react-devtools": "0.10.8",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/router-plugin": "1.168.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6",
    "eslint": "^9",
    "jsdom": "^28",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6",
    "vite": "^8",
    "vitest": "4.1.9"
  }
}
